# Anthropic — used by pipeline/script_generator.py to write daily horror scripts.
ANTHROPIC_API_KEY=

# YouTube Data API v3 — populated by running auth.py once locally.
# See pipeline/uploader.py and auth.py for the OAuth bootstrap flow.
# IMPORTANT: must be authorized for "The 3AM Tape" channel — NOT Money Crew.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Facebook Graph API — for Reels cross-posting (pipeline/facebook_uploader.py).
# FB_PAGE_ID: numeric Page ID (find it in Page → About → Page transparency).
# FB_PAGE_ACCESS_TOKEN: long-lived Page token. Use a System User token from
#   Meta Business Suite → System Users for a non-expiring token.
# Leave both blank to disable Facebook upload (pipeline runs YouTube-only).
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# Pipeline settings
OUTPUT_DIR=./outputs
LOG_LEVEL=INFO

# --- CI / Linux overrides (do NOT set on Mac dev machine) ---
# In GitHub Actions these come from the workflow `env:` block, not from .env.
# FFMPEG_BIN=ffmpeg
# FFPROBE_BIN=ffprobe
# CAPTION_FONT=/usr/share/fonts/truetype/liberation/LiberationSans-Bold.ttf

# --- GitHub Secrets needed for the daily.yml workflow ---
# Add these at: Settings → Secrets and variables → Actions → New repository secret
#   ANTHROPIC_API_KEY        (your Claude API key)
#   YOUTUBE_CLIENT_ID        (from auth.py output)
#   YOUTUBE_CLIENT_SECRET    (from auth.py output)
#   YOUTUBE_REFRESH_TOKEN    (from auth.py output)
#   FB_PAGE_ID               (numeric Facebook Page ID)
#   FB_PAGE_ACCESS_TOKEN     (long-lived / System User Page token)
